<meta charset="utf-8">
<style>
  table { border-collapse: collapse; width: 100%; font-family: 'Times New Roman', Times, serif; font-size: 13pt; margin-bottom: 30px; }
  th, td { border: 1px solid black; padding: 10px; text-align: left; vertical-align: top; }
  th { background-color: #f2f2f2; font-weight: bold; width: 25%; }
  td { width: 75%; }
  h3 { font-family: 'Times New Roman', Times, serif; font-size: 16pt; margin-bottom: 15px; }
</style>
